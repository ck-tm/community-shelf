# Django
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=api.library.costico.eu,localhost

# Database
POSTGRES_DB=communityshelf
POSTGRES_USER=communityshelf
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://communityshelf:changeme@db:5432/communityshelf

# Redis
REDIS_URL=redis://redis:6379/0

# CORS — frontend origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://library.costico.eu
# CSRF — trusted origins (comma-separated)
CSRF_TRUSTED_ORIGINS=https://library.costico.eu,https://api.library.costico.eu

# JWT cookie domain — leading dot shares across all subdomains
JWT_COOKIE_DOMAIN=.library.costico.eu

# Cloudflare Tunnel — get from Zero Trust dashboard
CLOUDFLARE_TUNNEL_TOKEN=

# Google OAuth2 (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sentry (optional)
SENTRY_DSN=

# Gunicorn
GUNICORN_WORKERS=3

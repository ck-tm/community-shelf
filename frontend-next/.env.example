# Django API URL — the Next.js proxy forwards /api/* requests here.
# For local dev with Django running locally:
#   NEXT_PUBLIC_API_URL=http://localhost:8000
# To connect to a remote production API:
#   NEXT_PUBLIC_API_URL=https://api-library.costico.eu
NEXT_PUBLIC_API_URL=https://api-library.costico.eu

# Base domain for subdomain-based tenant detection.
# In dev, tenants are accessed as <slug>.localhost:3000
NEXT_PUBLIC_BASE_DOMAIN=localhost

# Platform URL (for cross-links from tenant pages to the platform)
NEXT_PUBLIC_PLATFORM_URL=http://localhost:3000
